  "keyFeatures": [
    "Filecoin blockchain synchronization (mainnet, calibnet, devnet)",
    "High-performance JSON-RPC API server compatible with Lotus",
    "Ethereum compatibility layer (EVM transactions, EIP-1559)",
    "Built-in wallet management and FIL transfers",
    "Blockchain snapshot import/export (faster and less memory than Lotus)",
    "F3 (Fast Finality) sidecar support",
    "Prometheus metrics, health check endpoints, and Grafana integration",
    "P2P networking via libp2p (Kademlia DHT, gossipsub, bitswap)",
    "Docker-first deployment with multi-platform support",
    "RPC method filtering for public node operators"
  ],
  "publicApiSurface": [
    "forest (daemon binary)",
    "forest-cli (RPC client CLI)",
    "forest-wallet (wallet management CLI)",
    "forest-tool (maintenance utilities CLI)",
    "Filecoin.ChainGetTipSet",
